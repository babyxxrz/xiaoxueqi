# ==========================================
# 智能交通识别系统 - 后端环境配置
# 复制此文件为 .env 并填写实际值
# ==========================================

# --- SMTP 邮件配置（用于告警通知与验证码发送）---
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code
SMTP_FROM=your_email@qq.com
SMTP_USE_SSL=true

# --- JWT 认证配置 ---
JWT_SECRET_KEY=change-this-to-a-random-secret
AUTH_DEBUG=false

# --- 告警邮件配置 ---
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_NOTIFY_USER=true
ALERT_EMAIL_NOTIFY_ADMINS=true
ALERT_EMAIL_MAX_RETRIES=3
ALERT_EMAIL_RETRY_DELAY_SECONDS=10
