# SMTP 基础配置
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USE_SSL=false
SMTP_USER=your_group_email@qq.com
SMTP_AUTH_CODE=replace_with_email_authorization_code
SMTP_FROM=your_group_email@qq.com

# JWT
JWT_SECRET_KEY=replace_with_a_long_random_secret

# 登录验证码
VERIFY_CODE_EXPIRE_MINUTES=5
VERIFY_CODE_LENGTH=6
AUTH_DEBUG=false

# 告警邮件总开关
ALERT_EMAIL_ENABLED=true

# 自动重试
ALERT_EMAIL_MAX_RETRIES=3
ALERT_EMAIL_RETRY_DELAY_SECONDS=10

# 当前固定策略：
# 1. 每条告警发送给告警所属用户。
# 2. 每条告警同时发送给所有拥有真实有效邮箱的管理员。
# 3. 只对同一条告警的同一邮箱去重，不跨告警抑制。
